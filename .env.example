# Database (PostgreSQL with asyncpg)
DATABASE_URL=postgresql+asyncpg://repnex:repnex@localhost:5432/repnex
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
RUN_MIGRATIONS=True

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET=replace-with-a-64-char-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7
INVITE_TTL_HOURS=24

# Encryption
FERNET_KEY=replace-with-a-generated-fernet-key
FERNET_PREVIOUS_KEYS=

# OpenAI Integration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_TIMEOUT_S=20
LLM_MAX_RETRIES=2
INTENT_MIN_CONFIDENCE=0.6

# App Config
APP_ENV=development
APP_NAME=repnex-backend
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
GRACEFUL_SHUTDOWN_SECONDS=30

# Rate limiting
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_QUERY_PER_MIN=30
RATE_LIMIT_API_PER_MIN=120
WS_MSG_PER_MIN=30

# Query Execution Config
EXECUTOR_TIMEOUT_S=120
EXECUTOR_MAX_ROWS=100000
EXECUTOR_BATCH_SIZE=500
TARGET_POOL_MAX=64
TARGET_POOL_MIN_SIZE=1
TARGET_POOL_MAX_SIZE=5

# Email config
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=your_google_app_password
SMTP_FROM=you@example.com
APP_BASE_URL=http://localhost:3000
